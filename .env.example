# Copy to .env and fill in real values. Never commit .env.

# ----- Database -----
DATABASE_URL=postgresql://user:password@localhost:5432/bundlereseller_db

# 
# Get from https://dashboard.paystack.com → Settings → API Keys
# Must be the SECRET key (starts with sk_test_ for test, sk_live_ for live). Using the public key (pk_) here causes 502.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: where to send user after payment (Paystack appends ?reference=...). Required for production.
# Use your live frontend URL, e.g. https://yoursite.com (no trailing slash; Paystack appends ?reference=...)
# FRONTEND_URL=https://yoursite.com
# PAYSTACK_CALLBACK_URL=https://yoursite.com

# Optional: timeout in seconds for Paystack API (default 30). Increase if you get timeouts.
# PAYSTACK_TIMEOUT=60

# ----- GHDataConnect (required for bundle delivery) -----
# From their portal → API Documentation: Base URL below; API Key = Bearer Token (generate from Profile on dashboard).
GHDATA_BASE_URL=https://ghdataconnect.com/api
GHDATA_API_KEY=your_ghdata_bearer_token

# ----- Local testing (do NOT set in production) -----
# Set to true to allow POST /webhooks/simulate-success so you can test bundle delivery without making a real Paystack payment.
# ALLOW_WEBHOOK_SIMULATE=true

# Optional: send capacity in GB (1, 2) instead of MB (1000, 2000). Default MB.
# GHDATA_CAPACITY_UNIT=MB

# ----- Admin panel -----
# Used to protect /admin/* endpoints. Use a strong password; never commit .env.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_use_strong

# ----- Production (optional) -----
# Comma-separated list of allowed CORS origins, e.g. https://yoursite.com,https://admin.yoursite.com
# CORS_ORIGINS=https://yoursite.com
